# Local overrides, loaded automatically from `.env` (gitignored) by
# `Settings.load()` (server/config.py) whenever the game server starts
# (`make dev` / uvicorn). Copy this file to `.env` and uncomment what you
# need. Real process env vars still win over anything set here.

# --- Current dev setup (matches README "exercise zone-based gameplay") ---
# Run TrackingBox separately with the venue+zones config:
#   audience-tracker serve --config /path/to/TrackingBox/config.json --port 8000
# then these match its defaults, so usually nothing to set:
# TRACKING_WS_URL=ws://localhost:8000/ws
# TRACKING_HTTP_URL=http://localhost:8000
# GAME_HOST=0.0.0.0
# GAME_PORT=8100

# Ritual rebind (Phase 4) - zone id defined in dev/trackingbox.config.json
# RITUAL_ZONE_ID=ritual

# --- ElevenLabs TTS (admin console voice generation) ---
# Generation stays disabled (503 from the admin endpoint) until this is set.
# ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# --- PocketBase (persistence backend, issue #16) ---
# The game server persists all runtime state (sessions, bindings, rounds,
# answers, scores, show content) in PocketBase. The superuser credentials
# stay server-side only — never in a Docker build arg, never sent to
# browsers. Startup hard-fails if PocketBase is unreachable.
# POCKETBASE_URL=http://localhost:8090
# POCKETBASE_ADMIN_EMAIL=admin@example.com
# POCKETBASE_ADMIN_PASSWORD=changeme

# --- Other tunables (see server/config.py) ---
# REBIND_MAX_DISTANCE=0.15
# REBIND_MAX_GAP_S=8.0
# ORPHAN_AFTER_S=3.0
